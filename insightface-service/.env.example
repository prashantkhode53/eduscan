# InsightFace model: "buffalo_sc" (200 MB, fast) or "buffalo_l" (500 MB, best accuracy)
MODEL_NAME=buffalo_sc
DET_SIZE=640

# Matching thresholds (scores are in [0, 1] — ArcFace cosine mapped via (cos+1)/2)
MATCH_THRESHOLD=0.60
MARGIN_THRESHOLD=0.05

# Quality gates (applied before embedding generation)
MIN_FACE_SIZE_PX=60
MAX_YAW_DEG=30.0
MAX_PITCH_DEG=30.0
MAX_ROLL_DEG=25.0
MIN_DET_SCORE=0.60

# Redis (use redis://redis:6379 inside docker-compose, or a cloud Redis URL)
REDIS_URL=redis://localhost:6379
REDIS_EMB_TTL=0

# PostgreSQL — required for cache reload on startup; same Neon URL as the backend
DATABASE_URL=
