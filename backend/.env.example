DB_HOST=your_postgres_host
DB_PORT=5432
DB_NAME=neondb
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=true
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

JWT_SECRET=run_openssl_rand_hex_32_here
JWT_EXPIRES_IN=8h

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=EduScan <your_email@gmail.com>

PORT=3000
NODE_ENV=development

API_BASE_URL=http://YOUR_SERVER_IP:3000

# ── WhatsApp Module ───────────────────────────────────────────────────────────
# Session is stored on local filesystem; lost on restart — re-scan QR is acceptable
WA_SESSION_PATH=.wwebjs_auth
WA_CLIENT_ID=eduscan-wa-client
# Rate limiting for message endpoints (defaults: 30 requests per 60 seconds)
WA_RATE_LIMIT_WINDOW_MS=60000
WA_RATE_LIMIT_MAX=30
