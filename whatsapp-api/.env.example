# ── Add these to your EXISTING backend .env / Render environment variables ───
# Do NOT create a new .env — append to the existing one.

# WhatsApp session (stored on local filesystem; lost on restart — acceptable)
WA_SESSION_PATH=.wwebjs_auth
WA_CLIENT_ID=eduscan-wa-client

# Optional standalone API key for /whatsapp/* endpoints.
# If set, requests must include X-API-Key: <value> OR be upstream-authenticated.
# If unset, your existing auth middleware is the only gate.
WA_API_KEY=

# Rate limiting for message endpoints
WA_RATE_LIMIT_WINDOW_MS=60000
WA_RATE_LIMIT_MAX=30

# DATABASE_URL — already present in your existing backend, no need to duplicate.
